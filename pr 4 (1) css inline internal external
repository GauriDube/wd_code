<!DOCTYPE html>
<html>
<head>
    <title>CSS Types Demo</title>

    <!-- External CSS Link -->
    <link rel="stylesheet" href="style.css">

    <!-- Internal CSS -->
    <style>
        h2 {
            color: darkgreen;
            text-align: center;
            background-color: lightyellow;
            padding: 10px;
        }

        p {
            font-size: 18px;
  color: navy;
            line-height: 1.6;
        }
    </style>
</head>
<body>

    <!-- Inline CSS -->
    <h1 style="color: white; background-color: blue; text-align: center; padding: 15px;">
        Welcome to CSS Demo
    </h1>

    <!-- Internal CSS Applied -->
    <h2>Internal CSS Example</h2>

    <p>
        This paragraph is styled using internal CSS.
        Internal CSS is written inside the style tag.
    </p>
 <!-- External CSS Applied -->
    <table>
        <tr>
            <th>Name</th>
            <th>Course</th>
            <th>Marks</th>
        </tr>

        <tr>
            <td>Rahul</td>
            <td>HTML</td>
            <td>85</td>
        </tr>

        <tr>
            <td>Sneha</td>
            <td>CSS</td>
            <td>90</td>
        </tr>
    </table>

</body>
</html>




